{
  "version": "1.0",
  "lastUpdated": "2025-01-27",
  "workflow": {
    "specGeneration": {
      "enabled": true,
      "templates": {
        "feature": "docs/prompts/codex/spec-from-issue.md",
        "bugfix": "docs/prompts/codex/spec-from-issue.md",
        "experiment": "docs/prompts/codex/spec-from-issue.md"
      },
      "outputDir": "specs",
      "structure": {
        "feature": "specs/feature",
        "bugfix": "specs/bugfix",
        "experiment": "specs/experiment"
      }
    },
    "checklistGeneration": {
      "enabled": true,
      "outputDir": "docs/checklists",
      "types": ["implementation", "review", "deployment"]
    },
    "runbookGeneration": {
      "enabled": true,
      "outputDir": "docs/runbooks"
    }
  },
  "integration": {
    "speckit": {
      "enabled": true,
      "configPath": ".speckit/speckit.config.json"
    },
    "aiPlaybook": {
      "enabled": true,
      "profilePath": "docs/ai-playbook/codex-profile.md"
    }
  },
  "format": {
    "specs": "yaml",
    "checklists": "markdown",
    "runbooks": "markdown"
  }
}
