# Decoded Backend — unified env file for Docker stack (api + ai + meilisearch + redis + searxng)
# Usage: cp .env.backend.example .env.backend.prod  (or .env.backend.dev / .env.backend.staging)
#
# Docker Compose overrides internal service URLs automatically (MEILISEARCH_URL, REDIS_HOST, etc.)
# You only need to fill in external service credentials below.

# ─── Shared ───────────────────────────────────────────────
API_SERVER_GRPC_PORT=50053

# ─── API Server (Rust/Axum) ──────────────────────────────
ENV=production
HOST=0.0.0.0
PORT=8000
RUST_LOG=info
LOG_FORMAT=text
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Database — prod 역할 (#333: public.posts/users/solutions 등 검증본)
# 로컬: postgresql://postgres:postgres@localhost:54322/postgres  ← `supabase status`
# 스테이징/프로덕션: 원격 Supabase pooler URL
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
DB_MAX_CONNECTIONS=100
DB_MIN_CONNECTIONS=5
DB_CONNECT_TIMEOUT=30
DB_IDLE_TIMEOUT=600

# assets 프로젝트 (#333: raw_post_sources/raw_posts/pipeline_events)
# 로컬: cloud assets pooler URL (팀 공유) 또는 비워두면 DATABASE_URL 로 fallback(WARN)
# 운영: 필수. 미설정 시 api-server 부팅 panic. ai-server 는 이 URL 에만 쓴다.
ASSETS_DATABASE_URL=
ASSETS_DB_MAX_CONNECTIONS=20
ASSETS_DB_MIN_CONNECTIONS=2
ASSETS_DB_CONNECT_TIMEOUT=30
ASSETS_DB_IDLE_TIMEOUT=600
# ai-server asyncpg pool 크기
ASSETS_DATABASE_POOL_MIN=1
ASSETS_DATABASE_POOL_MAX=5

# assets Supabase REST (web 에서 읽기용, 선택)
ASSETS_DATABASE_API_URL=
ASSETS_DATABASE_ANON_KEY=
ASSETS_DATABASE_SERVICE_ROLE_KEY=

# APP_ENV: AppEnv (Local/Production)
# - Local: verify 엔드포인트가 cloud assets 의 status write 를 스킵 → 공유 데이터 오염 방지
# - Production: verify 성공 시 assets status=VERIFIED + pipeline_events 기록
APP_ENV=production

# #282: dev 에서는 supabase/migrations/*.sql 이 SOT. SeaORM 마이그레이션과 충돌하므로
# self-hosted 로컬에서만 1 로 설정. staging/prod 에서는 false 또는 unset (SeaORM 사용).
SKIP_DB_MIGRATIONS=1

# Auth (GoTrue REST endpoint + JWT secret)
# 로컬: Supabase CLI 기동 후 `supabase status` 에서 anon / service_role / JWT secret 복사
# 원격: Supabase Dashboard > Settings > API
# Legacy SUPABASE_* names still read as fallback during rollout; remove after #268 cleanup.
DATABASE_API_URL=http://127.0.0.1:54321
DATABASE_ANON_KEY=eyJhbGc...
DATABASE_SERVICE_ROLE_KEY=eyJhbGc...
DATABASE_JWT_SECRET=your-jwt-secret

# Meilisearch
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=your-master-key

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=decoded-images
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# Affiliate
RAKUTEN_API_KEY=your-rakuten-key
RAKUTEN_PUBLISHER_ID=your-publisher-id

# AI Queue gRPC (API -> ai-server)
AI_SERVER_GRPC_URL=http://localhost:50052

# Vector Search (OpenAI Embeddings)
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=256

# ─── AI Server (Python/gRPC) ─────────────────────────────
# APP_ENV 은 상단 api-server 섹션에서 공유 (동일 파일이라 중복 정의 금지)

JWT_SECRET_KEY=your-jwt-secret-change-me
JWT_ALGORITHM=HS256

LOG_LEVEL=INFO
# Note: LOG_FORMAT is set per-service in docker-compose (api=text, ai=json)

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0

QUEUE_BATCH_SIZE=10

API_SERVER_HTTP_URL=http://localhost:8000
API_SERVER_ACCESS_TOKEN=your_backend_token

SELENIUM_URL=http://localhost:4444

API_SERVER_GRPC_HOST=localhost

PERPLEXITY_API_KEY=
PERPLEXITY_API_URL=https://api.perplexity.ai
PERPLEXITY_MODEL=sonar
PERPLEXITY_MAX_RETRIES=3
PERPLEXITY_REQUEST_TIMEOUT=30

SEARXNG_API_URL=http://localhost:4000
SEARXNG_MAX_RETRIES=3
SEARXNG_REQUEST_TIMEOUT=10

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false

BATCH_SIZE=10
MAX_CONCURRENT_REQUESTS=5
REQUEST_TIMEOUT=30
MAX_RETRIES=3
