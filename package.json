{
  "name": "decoded-monorepo",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/web",
    "packages/shared",
    "packages/mobile",
    "packages/api-server",
    "packages/ai-server"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "bun run --filter @decoded/web dev",
    "dev:api-server": "cd packages/api-server && cargo watch -x run",
    "dev:ai-server": "cd packages/ai-server && uv run python -m src.main",
    "dev:local-fe": "bun run dev:web",
    "dev:local-be": "bash scripts/local-be.sh",
    "dev:local-deps": "bash scripts/local-deps-up.sh",
    "dev:local-deps-down": "bash scripts/local-deps-down.sh",
    "dev:backend": "bun run dev:api-server",
    "build": "turbo run build",
    "build:web": "bun run --filter @decoded/web build",
    "build:api-server": "cd packages/api-server && cargo build --release",
    "build:backend": "bun run build:api-server",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "turbo": "^2"
  },
  "overrides": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
