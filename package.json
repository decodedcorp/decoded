{
  "name": "decoded-monorepo",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/web",
    "packages/shared",
    "packages/mobile"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "bun run --filter @decoded/web dev",
    "dev:backend": "cd packages/backend && cargo watch -x run",
    "build": "turbo run build",
    "build:web": "bun run --filter @decoded/web build",
    "build:backend": "cd packages/backend && cargo build --release",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "turbo": "^2"
  },
  "overrides": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
