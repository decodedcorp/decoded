{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "generate:api": {
      "outputs": ["lib/api/generated/**"]
    },
    "build": {
      "dependsOn": ["^build", "generate:api"],
      "outputs": [".next/**", "dist/**"]
    },
    "typecheck": {
      "dependsOn": ["generate:api"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["generate:api"]
    }
  }
}
