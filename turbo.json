{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "generate:api": {
      "outputs": ["lib/api/generated/**"]
    },
    "build": {
      "dependsOn": ["^build", "generate:api"],
      "outputs": [".next/**", "dist/**"],
      "passThroughEnv": [
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "NEXT_PUBLIC_SITE_URL",
        "NEXT_PUBLIC_API_BASE_URL",
        "NEXT_PUBLIC_SENTRY_DSN",
        "NEXT_PUBLIC_GOOGLE_CLIENT_ID",
        "NEXT_PUBLIC_GOOGLE_REDIRECT_URI",
        "NEXT_PUBLIC_REDIRECT_URI",
        "NEXT_PUBLIC_DB_ENDPOINT",
        "NEXT_PUBLIC_WS_URL",
        "NEXT_PUBLIC_SERVICE_ENDPOINT",
        "NEXT_PUBLIC_TELEGRAM_CHANNEL_URL",
        "API_BASE_URL",
        "BACKEND_URL",
        "GOOGLE_CLIENT_SECRET",
        "SENTRY_DSN",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "SENTRY_AUTH_TOKEN"
      ]
    },
    "typecheck": {
      "dependsOn": ["generate:api"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["generate:api"]
    }
  }
}
