# 로컬 개발용 템플릿 (호스트에서 API 실행 + Supabase CLI 로 의존 스택 기동)
# 사용: cp .env.dev.example .env.dev
# ai-server `.dev.env` 의 API_SERVER_GRPC_PORT 는 이 파일의 API_SERVER_GRPC_PORT 와 같아야 합니다.
#
# Supabase self-hosted 기준 (#282):
#   - `just local-deps` 로 기동
#   - DATABASE_URL / DATABASE_API_URL 은 `supabase status` 출력값과 일치
#   - DATABASE_ANON_KEY / DATABASE_SERVICE_ROLE_KEY / DATABASE_JWT_SECRET 은 `supabase status` 복사
#   - DATABASE_* 만 사용 (legacy SUPABASE_* 는 #345 에서 제거됨)

ENV=development
HOST=0.0.0.0
PORT=8000
RUST_LOG=info
LOG_FORMAT=text
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Local Supabase Postgres (supabase CLI) — prod 역할 (#333: public.posts 등)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
DB_MAX_CONNECTIONS=100
DB_MIN_CONNECTIONS=5
DB_CONNECT_TIMEOUT=30
DB_IDLE_TIMEOUT=600

# assets 프로젝트 (#333: raw_post_sources/raw_posts/pipeline_events)
# 로컬: cloud assets pooler URL (팀 공유 시크릿). 비워두면 DATABASE_URL 로 fallback + WARN.
ASSETS_DATABASE_URL=
ASSETS_DB_MAX_CONNECTIONS=20
ASSETS_DB_MIN_CONNECTIONS=2
ASSETS_DB_CONNECT_TIMEOUT=30
ASSETS_DB_IDLE_TIMEOUT=600

# APP_ENV: Local → verify 엔드포인트가 cloud assets 쓰기를 스킵 (공유 오염 방지)
APP_ENV=local

# #282: dev 에서는 supabase/migrations/*.sql 이 SOT. SeaORM 마이그레이션 객체와
# 충돌하므로 self-hosted 로컬에서는 반드시 1 로 설정.
# staging/prod 에서는 SeaORM 을 사용하므로 false 또는 unset.
SKIP_DB_MIGRATIONS=1

API_SERVER_GRPC_PORT=50053

# Auth — 로컬 GoTrue (supabase CLI). `supabase status` 로 값 확인.
DATABASE_API_URL=http://127.0.0.1:54321
DATABASE_ANON_KEY=
DATABASE_SERVICE_ROLE_KEY=
DATABASE_JWT_SECRET=

MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=dev-master-key

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=decoded-images
R2_PUBLIC_URL=

RAKUTEN_API_KEY=
RAKUTEN_PUBLISHER_ID=

AI_SERVER_GRPC_URL=http://localhost:50052

OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=256
