# Environment
# 로컬에서 `cargo run` / `local-be` 시: 아래 Meilisearch·AI gRPC 는 localhost + compose 포트를 쓰세요.
# Docker 네트워크 안(api 컨테이너)에서 돌릴 때만 meilisearch, decoded-ai-api-dev 같은 호스트명을 씁니다.
ENV=development
HOST=0.0.0.0
PORT=8000
RUST_LOG=info
LOG_FORMAT=text
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Database (Postgres — local container or remote Supabase host; transparent)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/decoded
DB_MAX_CONNECTIONS=100
DB_MIN_CONNECTIONS=5
DB_CONNECT_TIMEOUT=30
DB_IDLE_TIMEOUT=600

# gRPC — API가 AI 콜백용으로 리스닝하는 포트. ai-server 의 API_SERVER_GRPC_PORT 와 반드시 동일해야 함.
# (레거시: GRPC_PORT)
API_SERVER_GRPC_PORT=50053

# Auth (remote Supabase project — JWT issuer + GoTrue REST endpoint)
# Legacy SUPABASE_* names still read as fallback during #268 rollout.
DATABASE_API_URL=https://[PROJECT-REF].supabase.co
DATABASE_ANON_KEY=eyJhbGc...
DATABASE_SERVICE_ROLE_KEY=eyJhbGc...
DATABASE_JWT_SECRET=your-jwt-secret

# Meilisearch — 로컬: `bun run dev:local-deps` 후 호스트 포트 7700 (docker-compose dev 와 동일)
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=your-master-key

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=decoded-images
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# Affiliate
RAKUTEN_API_KEY=your-rakuten-key
RAKUTEN_PUBLISHER_ID=your-publisher-id

# AI Queue gRPC (API → ai-server) — 로컬: ai-server 가 APP_ENV=dev 일 때 Queue 는 보통 50052 (packages/ai-server/src/main.py)
# (레거시: DECODED_AI_GRPC_URL)
AI_SERVER_GRPC_URL=http://localhost:50052

# Vector Search (OpenAI Embeddings)
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=256
