{
  "dashboard": {
    "title": "Application Logs",
    "tags": ["logs", "application"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 0,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Application Logs",
        "type": "logs",
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 0
        },
        "targets": [
          {
            "expr": "{container=~\"decoded-api.*\", service=\"decoded-api\"}",
            "refId": "A"
          }
        ],
        "options": {
          "dedupStrategy": "none",
          "enableLogDetails": true,
          "prettifyLogMessage": false,
          "showCommonLabels": false,
          "showLabels": false,
          "showTime": true,
          "sortOrder": "Descending",
          "wrapLogMessage": false
        }
      },
      {
        "id": 2,
        "title": "Logs by Level",
        "type": "bargauge",
        "gridPos": {
          "h": 4,
          "w": 12,
          "x": 0,
          "y": 8
        },
        "targets": [
          {
            "expr": "sum by (level) (count_over_time({container=~\"decoded-api.*\"}[5m]))",
            "refId": "A"
          }
        ]
      },
      {
        "id": 3,
        "title": "Recent Errors",
        "type": "logs",
        "gridPos": {
          "h": 6,
          "w": 12,
          "x": 12,
          "y": 8
        },
        "targets": [
          {
            "expr": "{container=~\"decoded-api.*\", level=\"error\"}",
            "refId": "A"
          }
        ],
        "options": {
          "dedupStrategy": "none",
          "enableLogDetails": true,
          "prettifyLogMessage": false,
          "showCommonLabels": false,
          "showLabels": false,
          "showTime": true,
          "sortOrder": "Descending",
          "wrapLogMessage": false
        }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {},
    "templating": {
      "list": []
    }
  }
}

