# 로컬 개발 (호스트에서 uv run) + Docker 는 redis/searxng 만
# 사용: cp .dev.env.example .dev.env 후 토큰·키를 채우세요.
# api-server .env.dev 의 GRPC_PORT 와 GRPC_BACKEND_PORT 를 맞추세요.

APP_ENV=dev

JWT_SECRET_KEY=dev-jwt-secret-change-me
JWT_ALGORITHM=HS256

LOG_LEVEL=INFO
LOG_FORMAT=json

REDIS_HOST=localhost
REDIS_PORT=6303
REDIS_PASSWORD=password
REDIS_DB=0

QUEUE_BATCH_SIZE=10

DECODED_BACKEND_URL=http://localhost:8000
DECODED_BACKEND_ACCESS_TOKEN=your_backend_token

SELENIUM_URL=http://localhost:4444

GRPC_BACKEND_HOST=localhost
GRPC_BACKEND_PORT=50053

PERPLEXITY_API_KEY=
PERPLEXITY_API_URL=https://api.perplexity.ai
PERPLEXITY_MODEL=sonar
PERPLEXITY_MAX_RETRIES=3
PERPLEXITY_REQUEST_TIMEOUT=30

SEARXNG_API_URL=http://localhost:4000
SEARXNG_MAX_RETRIES=3
SEARXNG_REQUEST_TIMEOUT=10

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false

BATCH_SIZE=10
MAX_CONCURRENT_REQUESTS=5
REQUEST_TIMEOUT=30
MAX_RETRIES=3
