# Mac 환경을 위한 기본 이미지 사용
# google-genai가 TypedDict extra_items 사용 (Python 3.12+ 필요)
FROM python:3.12-slim

# 필요한 시스템 패키지 설치
RUN apt-get update && apt-get install -y \
    gcc \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir uv

WORKDIR /app

# 의존성 파일 복사 및 설치 (개발 그룹 포함)
COPY pyproject.toml uv.lock ./
RUN mkdir -p /app/db
RUN mkdir -p /app/logs
RUN uv sync --frozen

COPY src/ /app/src/
COPY README.md /app/

ENV PYTHONPATH=/app

EXPOSE 10000 50052

CMD ["uv", "run", "python", "-m", "src.main"]
