# AI Server — 예시 (복사: cp .env.example .env)
# 필수 필드는 Environment (src/config/_environment.py) 와 이름이 일치해야 합니다.

# APP_ENV=dev 일 때 Queue gRPC 는 main.py 에서 50052 로 바인딩됩니다 (api-server 의 AI_SERVER_GRPC_URL 과 맞출 것).
APP_ENV=dev

HOST=0.0.0.0
PORT=10000

JWT_SECRET_KEY=dev-jwt-secret-change-me
JWT_ALGORITHM=HS256

LOG_LEVEL=INFO
LOG_FORMAT=json

# Redis — 로컬: docker-compose-ai-dev.yml publish 6303, requirepass password
REDIS_HOST=localhost
REDIS_PORT=6303
REDIS_PASSWORD=password
REDIS_DB=0

QUEUE_BATCH_SIZE=10

# Rust API HTTP
API_SERVER_HTTP_URL=http://localhost:8000
API_SERVER_ACCESS_TOKEN=your_backend_token

SELENIUM_URL=http://localhost:4444

# Rust API 콜백 gRPC — api-server 의 API_SERVER_GRPC_PORT 와 동일
API_SERVER_GRPC_HOST=localhost
API_SERVER_GRPC_PORT=50053

PERPLEXITY_API_KEY=
PERPLEXITY_API_URL=https://api.perplexity.ai
PERPLEXITY_MODEL=sonar
PERPLEXITY_MAX_RETRIES=3
PERPLEXITY_REQUEST_TIMEOUT=30

SEARXNG_API_URL=http://localhost:4000
SEARXNG_MAX_RETRIES=3
SEARXNG_REQUEST_TIMEOUT=10

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false

PERPLEXITY_INITIAL_CREDITS=100.0

BATCH_SIZE=10
MAX_CONCURRENT_REQUESTS=5
REQUEST_TIMEOUT=30
MAX_RETRIES=3
