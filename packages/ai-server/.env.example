# AI Server Configuration Example
# Copy this file to .env and configure with your actual values

# Server Settings
HOST=0.0.0.0
PORT=10000
GRPC_PORT=50051

# External API Configuration
# Perplexity API (required for link/image analysis)
PERPLEXITY_API_KEY=your_perplexity_api_key_here
PERPLEXITY_API_URL=https://api.perplexity.ai
PERPLEXITY_MODEL=sonar
PERPLEXITY_MAX_RETRIES=3
PERPLEXITY_REQUEST_TIMEOUT=30

# SearXNG API (required for image search)
SEARXNG_API_URL=https://your-searxng-instance.com
SEARXNG_MAX_RETRIES=3
SEARXNG_REQUEST_TIMEOUT=10

# Telegram Bot Configuration (for cost notifications)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_ENABLED=true

# Perplexity Credit Management
PERPLEXITY_INITIAL_CREDITS=100.0

# Processing Configuration
BATCH_SIZE=10
MAX_CONCURRENT_REQUESTS=5
REQUEST_TIMEOUT=30
MAX_RETRIES=3

# Backend Connection
BACKEND_GRPC_HOST=localhost
BACKEND_GRPC_PORT=50050

# Redis Configuration (existing)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Existing configuration
APP_ENV=development
DECODED_BACKEND_ACCESS_TOKEN=your_backend_token

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json