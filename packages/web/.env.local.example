# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Shared Supabase (optional, falls back to NEXT_PUBLIC_*)
# SHARED_SUPABASE_URL=
# SHARED_SUPABASE_ANON_KEY=

# Backend API
API_BASE_URL=http://localhost:3100

# Virtual Try-On (GCP)
# GCP_PROJECT_ID=decoded-editorial
# GCP_LOCATION=us-central1
# GCP_ACCESS_TOKEN=

# E2E Test credentials (never commit real values)
# TEST_USER_EMAIL=test@example.com
# TEST_USER_PASSWORD=your-test-user-password

# Debug
# NEXT_PUBLIC_DEBUG=true

# Sentry (error tracking)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
# SENTRY_AUTH_TOKEN=sntrys_xxx (build-time only, for source map upload)
