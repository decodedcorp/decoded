# Auth — 로컬 Supabase CLI 기본 (#282). `supabase status` 에서 anon key 복사.
# 원격으로 붙이려면 프로젝트 URL / Dashboard anon key 사용.
# Legacy NEXT_PUBLIC_SUPABASE_* 는 #345 에서 제거됨 — DATABASE_* 만 사용.
NEXT_PUBLIC_DATABASE_API_URL=http://127.0.0.1:54321
NEXT_PUBLIC_DATABASE_ANON_KEY=your-local-anon-key

# Shared pipeline DB (optional, falls back to NEXT_PUBLIC_DATABASE_*)
# SHARED_DATABASE_URL=
# SHARED_DATABASE_ANON_KEY=

# Backend API
API_BASE_URL=http://localhost:3100

# ai-server (FastAPI) — manual trigger for raw_posts scheduler etc.
AI_SERVER_URL=http://localhost:10000

# Virtual Try-On (GCP)
# GCP_PROJECT_ID=decoded-editorial
# GCP_LOCATION=us-central1
# GCP_ACCESS_TOKEN=

# E2E Test credentials (never commit real values)
# TEST_USER_EMAIL=test@example.com
# TEST_USER_PASSWORD=your-test-user-password

# Debug
# NEXT_PUBLIC_DEBUG=true

# Sentry (error tracking)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
# SENTRY_AUTH_TOKEN=sntrys_xxx (build-time only, for source map upload)
