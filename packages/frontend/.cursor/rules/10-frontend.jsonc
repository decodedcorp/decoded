{
  "name": "frontend-rules",
  "description": "Frontend-specific rules for React/Next.js development",
  "priority": 10,
  "patterns": [
    "src/**/*.{ts,tsx}",
    "app/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
  ],
  "config": {
    "framework": {
      "name": "Next.js",
      "version": "latest",
      "language": "TypeScript",
    },
    "instructions": [
      "Use React + TypeScript with strict typing.",
      "Prefer hooks and composition over inheritance.",
      "Keep components small and focused on a single responsibility.",
      "Use proper TypeScript types - avoid 'any'.",
      "For UI changes, describe accessibility impact (focus, roles, labels, ARIA).",
      "Follow React best practices: hooks, functional components, proper dependency arrays.",
      "Use Next.js conventions: App Router, Server Components when appropriate.",
      "Ensure responsive design and mobile optimization.",
      "Add proper error boundaries for error handling.",
      "Use proper semantic HTML elements.",
    ],
    "code_quality": {
      "strict_mode": true,
      "no_any": true,
      "small_functions": true,
      "composable_components": true,
    },
  },
}
