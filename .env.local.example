# === Local Development Quick Start ===
# 1. Copy this file: cp .env.local.example .env.local
# 2. Set NEXT_PUBLIC_DATABASE_API_URL and NEXT_PUBLIC_DATABASE_ANON_KEY
#    (pointing at your remote Supabase project — auth only in Path X-1)
# 3. API_BASE_URL is already set to localhost:8000
# 4. Ensure backend CORS allows http://localhost:3000
#    (ALLOWED_ORIGINS=http://localhost:3000 in backend .env)
# =====================================

# Auth config (remote Supabase project — used for login/JWT issue only)
# DO NOT commit .env.local to git (already in .gitignore)
# Legacy NEXT_PUBLIC_SUPABASE_* names still work as fallback during #268 rollout.

# Supabase project URL (e.g. https://xxx.supabase.co)
NEXT_PUBLIC_DATABASE_API_URL=

# Supabase public anon key (NEVER use service role key here)
# Get this from: Supabase Dashboard > Settings > API > Project API keys > anon public
NEXT_PUBLIC_DATABASE_ANON_KEY=

# Server-side only (DO NOT expose to browser)
# Get this from: Supabase Dashboard > Settings > API > Project API keys > service_role
# WARNING: This key has admin privileges. Never use NEXT_PUBLIC_ prefix for this variable.
DATABASE_SERVICE_ROLE_KEY=

# API Configuration
# Server-side only: Backend API base URL for proxy routes
# This is used by Next.js API Routes to forward requests to the actual backend
# WARNING: Do NOT use NEXT_PUBLIC_ prefix - this should never be exposed to the browser
# Local backend: http://localhost:8000 | Production: https://dev.decoded.style
API_BASE_URL=http://localhost:8000

# Client-side: API base URL for browser requests
# Optional when using Next.js API Routes as proxy (recommended, current pattern)
# Leave empty to use the proxy — set to backend URL only if CORS is configured on backend
NEXT_PUBLIC_API_BASE_URL=
