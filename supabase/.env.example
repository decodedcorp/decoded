# Supabase CLI 가 읽는 env (로컬 self-hosted, #282).
#
# 사용:
#   cp supabase/.env.example supabase/.env
#   # 값을 채운 뒤
#   supabase stop && supabase start
#
# 이 파일은 .gitignore 의 `.env` 패턴으로 자동 ignored.
# config.toml 의 `env(SUPABASE_AUTH_EXTERNAL_GOOGLE_*)` 가 이 값으로 치환됨.

# ─── Google OAuth ──────────────────────────────────────────
# Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client
# Redirect URI 에 반드시 추가: http://127.0.0.1:54321/auth/v1/callback
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# ─── 기타 OAuth (필요 시 활성화) ─────────────────────────
# SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=
# SUPABASE_AUTH_EXTERNAL_KAKAO_CLIENT_ID=
# SUPABASE_AUTH_EXTERNAL_KAKAO_SECRET=
