{
  "permissions": {
    "allow": [
      "Bash(bun:*)",
      "Bash(bun run:*)",
      "Bash(bunx:*)",
      "Bash(turbo:*)",
      "Bash(cargo:*)",
      "Bash(cargo check:*)",
      "Bash(cargo build:*)",
      "Bash(cargo test:*)",
      "Bash(cargo run:*)",
      "Bash(npx tsc:*)",
      "Bash(npx playwright:*)",
      "Bash(yarn type-check)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Agent",
      "mcp__pencil__get_screenshot",
      "mcp__pencil__batch_get",
      "mcp__pencil__get_style_guide",
      "mcp__pencil__get_guidelines"
    ],
    "deny": [
      "Bash(rm -rf packages/)",
      "Bash(git push --force origin main)",
      "Bash(cargo publish:*)"
    ]
  },
  "worktree": {
    "symlinkDirectories": [
      "node_modules",
      ".next",
      "packages/api-server/target"
    ]
  }
}
