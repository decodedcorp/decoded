    {
      "id": "store_content",
      "type": "text",
      "x": 120,
      "y": 420,
      "width": 310,
      "height": 140,
      "text": "interface TransitionStore {\n  state: 'idle' | 'capturing' | 'animating'\n  sourceElement: HTMLElement | null\n  targetId: string | null\n  flipState: Flip.FlipState | null\n  \n  capture: (el, id) => void\n  animate: () => void\n  reset: () => void\n}",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "opacity": 100
    },
    {
      "id": "section_config",
      "type": "text",
      "x": 520,
      "y": 360,
      "width": 200,
      "height": 25,
      "text": "FLIP Configuration",
      "fontSize": 18,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "opacity": 100
    },
    {
      "id": "config_box",
      "type": "rectangle",
      "x": 520,
      "y": 400,
      "width": 300,
      "height": 180,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#f8f9fa",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "opacity": 100,
      "roundness": { "type": 3 }
