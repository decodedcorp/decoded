    {
      "id": "config_content",
      "type": "text",
      "x": 540,
      "y": 420,
      "width": 260,
      "height": 140,
      "text": "Flip.from(flipState, {\n  duration: 0.5,\n  ease: 'power2.inOut',\n  scale: true,\n  absolute: true,\n  onComplete: () => {\n    transitionStore.reset()\n  }\n})",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
